# Database Configuration
DATABASE_URL=./data.db

# Server Configuration
NODE_ENV=development
PORT=5000

# Authentication
SESSION_SECRET=change-this-to-a-secure-random-string

# Replit Auth (if using Replit deployment)
REPLIT_DOMAINS=your-replit-domain.repl.co

# Camera Monitoring Configuration
DEFAULT_CHECK_INTERVAL=300000
DEFAULT_TIMEOUT=5000
MAX_CONCURRENT_CHECKS=10

# Security
BCRYPT_ROUNDS=10
SESSION_MAX_AGE=86400000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Email Notifications (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=Axis Camera Monitor <noreply@example.com>

# Alert Configuration
ENABLE_EMAIL_ALERTS=false
ALERT_EMAIL_RECIPIENTS=admin@example.com

# Advanced Features
ENABLE_NETWORK_SCAN=true
ENABLE_AUTO_DISCOVERY=true
ENABLE_RELIABILITY_METRICS=true
